collabrains.eu {
	encode gzip

	# Responses on this site differ by the Accept header (see @api below),
	# so caches (browser HTTP cache included) must not conflate a page
	# navigation's response with a same-URL fetch() call's response, or a
	# client-side route like /documents/:id can silently start serving the
	# API's JSON (or vice versa) after the first request. Without this,
	# browsers may reuse an SPA-fallback response cached under the page
	# navigation's Accept: text/html for a later fetch() with no Accept
	# header at all, since Chromium's fetch() omits Accept when unset.
	header Vary Accept

	# Security headers (ADR 0066 P1: none of these existed before -- a
	# single XSS bug anywhere in the SPA or a dependency had no
	# defense-in-depth backstop). CSP sources are scoped to what the app
	# actually loads: Google Fonts CSS+files (src/index.css `@import`),
	# and the one absolute-URL fetch() in Landing.tsx's best-effort IP
	# geolocation (ipapi.co). `style-src 'unsafe-inline'` is needed for
	# React/Tailwind/framer-motion's inline `style=` attributes (dynamic
	# widths, animation values) -- far lower risk than `script-src
	# 'unsafe-inline'`, which is deliberately not granted anywhere here.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=()"
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://ipapi.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
	}

	# The SPA has client-side routes that share a path prefix with API
	# routes (e.g. GET /documents/:id is both a frontend page and a REST
	# endpoint). Browser page navigations send Accept: text/html; the
	# frontend's own fetch() calls don't, so that's what disambiguates them.
	@api {
		not header Accept *text/html*
		path /auth* /documents* /chat* /legal* /tasks* /entities* /search* /health* /plans* /memories* /tools* /mcp* /decisions* /manager* /preferences* /organizations* /learning* /cases* /vehicles* /admin* /facts* /categories* /appointments* /users* /feedback* /workspace* /activity* /share*
	}
	handle @api {
		reverse_proxy api:8000
	}

	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}

# --- Postgres ---
POSTGRES_USER=collabrains
POSTGRES_PASSWORD=changeme
POSTGRES_DB=collabrains
DATABASE_URL=postgresql+asyncpg://collabrains:changeme@postgres:5432/collabrains

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API / Auth ---
JWT_SECRET=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- Elasticsearch (unused by the API -- search is Postgres-native, see
#     docs/adr/0002-phase1b-document-pipeline.md. Service still available
#     behind --profile full for hosts that support it.) ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- Ollama ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Paperless-ngx ---
PAPERLESS_SECRET_KEY=changeme-generate-a-real-secret
PAPERLESS_URL=http://paperless:8000
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=changeme

# --- Signal (Phase 3) ---
SIGNAL_PHONE_NUMBER=
SIGNAL_CLI_URL=http://signal-cli:8080

# --- LDAP ---
LDAP_ADMIN_PASSWORD=changeme
LDAP_URL=ldap://openldap:389
LDAP_BASE_DN=dc=collabrains,dc=eu
LDAP_BIND_DN_TEMPLATE=uid={username},ou=people,dc=collabrains,dc=eu
LDAP_ADMIN_GROUP_DN=cn=collabrains-admins,ou=groups,dc=collabrains,dc=eu

# --- Postgres ---
POSTGRES_USER=collabrains
POSTGRES_PASSWORD=changeme
POSTGRES_DB=collabrains
DATABASE_URL=postgresql+asyncpg://collabrains:changeme@postgres:5432/collabrains

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API / Auth ---
JWT_SECRET=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256
# Comma-separated. Only matters for cross-origin browser callers -- prod
# traffic goes through Caddy same-origin and never hits this check. Add a
# second origin here (don't just widen to "*") if a real cross-origin
# browser client is ever needed. See docs/adr/0066.
CORS_ALLOWED_ORIGINS=http://localhost:5173
JWT_EXPIRE_MINUTES=60

# --- Elasticsearch (unused by the API -- search is Postgres-native, see
#     docs/adr/0002-phase1b-document-pipeline.md. Service still available
#     behind --profile full for hosts that support it.) ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- Ollama / AI Gateway (see docs/adr/0003 and docs/deployment/ai-optimization.md) ---
OLLAMA_URL=http://ollama:11434
# qwen3:8b is verified-correct for manager_agent's tool-calling despite its size --
# smaller models (tested: qwen2.5:3b-instruct, qwen2.5-coder:1.5b) produce garbled/
# hallucinated/wrong-language output or skip real tool calls entirely on this app's
# actual usage pattern. See docs/deployment/ai-optimization.md before downsizing.
CHAT_MODEL=qwen3:8b
# Used only by the dedicated POST /manager/reason endpoint (single-shot reasoning,
# not manager_agent's tool-calling loop) -- live-verified coherent at this size.
REASONING_MODEL=deepseek-r1:1.5b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
AI_RATE_LIMIT_PER_MINUTE=30
AI_MAX_CONTEXT_CHUNKS=5

# --- Paperless-ngx ---
PAPERLESS_SECRET_KEY=changeme-generate-a-real-secret
PAPERLESS_URL=http://paperless:8000
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=changeme

# --- Signal (Phase 3a, see docs/adr/0005-phase3a-signal-bot.md) ---
SIGNAL_PHONE_NUMBER=
SIGNAL_CLI_URL=http://signal-cli:8080

# --- Monitoring (Phase 6c) ---
# Phone number (E.164) the watchdog alerts when a health check fails.
ALERT_PHONE_NUMBER=
COLLABRAINS_API_URL=http://api:8000
# Long-lived JWT for the signal-bot service account (Postgres user
# username=signal-bot, role=service). Mint with the snippet in the ADR --
# there is no login flow for it since it has no LDAP identity.
SIGNAL_BOT_API_TOKEN=

# --- Backups (Phase 6b, ADR 0066 Priority 1) ---
# Required -- infra/backup/backup.sh refuses to run without it. Every
# dump is piped through `gpg --symmetric` with this as the passphrase, so
# plaintext never touches disk. Generate with e.g. `openssl rand -base64
# 32`; store it somewhere other than this file (a password manager, not
# a copy in the repo) -- anyone with this value and a backup file can
# read Postgres, every LDAP password hash, and the Signal identity keys.
BACKUP_ENCRYPTION_PASSPHRASE=changeme-generate-a-real-passphrase

# --- Sentry error tracking (ADR 0066/0072, Priority 2 item 4) ---
# Empty by default -- the SDK is never initialized (fully inert) without a
# DSN, in local dev, CI, and tests alike. send_default_pii/local-variable
# capture/session replay are all deliberately off regardless of this value
# -- see services/api/src/api/sentry_config.py for why.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- LDAP ---
LDAP_ADMIN_PASSWORD=changeme
LDAP_URL=ldap://openldap:389
LDAP_BASE_DN=dc=collabrains,dc=eu
LDAP_BIND_DN_TEMPLATE=uid={username},ou=people,dc=collabrains,dc=eu
LDAP_ADMIN_GROUP_DN=cn=collabrains-admins,ou=groups,dc=collabrains,dc=eu

# --- App base URL (used to build links in emails: self-service signup
#     verification, org invitations, admin-created-user welcome links) ---
# Real incident, ADR 0073: left unset once, so every emailed link silently
# pointed at the wrong domain. Must be the real public URL, no trailing slash.
APP_BASE_URL=https://collabrains.eu

# --- Outbound email (self-service signup, invitations, admin welcome links) ---
# Best-effort: leaving this unset doesn't break signup/invitations, it just
# means the verification/invite email is never sent -- see
# services/api/src/api/email_client.py.
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@collabrains.eu

# --- Stripe billing (Priority 3 commercial SaaS, ADR 0074) ---
# Empty by default -- billing_router.py's checkout/portal/webhook endpoints
# return a 503 rather than calling Stripe with no key configured, same "stay
# inert until configured" contract SENTRY_DSN/SMTP_HOST already use. Price
# IDs are per-plan lookups, not hardcoded, so switching a test-mode account
# to live (or repricing a plan) is a config change, not a code change.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=

# --- Plausible analytics (Priority 3 commercial SaaS, ADR 0074) ---
# Frontend-only (apps/web/.env.production[.local], not this file -- see
# apps/web/src/lib/analytics.ts). Empty by default -- the script is never
# injected and window.plausible is never called without a domain, same
# "stays inert until configured" contract as everything else above.
# VITE_PLAUSIBLE_DOMAIN=collabrains.eu
# VITE_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.js

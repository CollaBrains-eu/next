# Python
__pycache__/
*.pyc
.venv/
.uv/
*.egg-info/

# Node
node_modules/
dist/
.pnpm-store/

# Env
.env
.env.local

# OS
.DS_Store

# Docker
*.log

# IDE
.vscode/
.idea/

# TS build artifacts
*.tsbuildinfo
vite.config.d.ts

# Signal registration data (identity/session keys — never commit)
infra/signal-cli/
.expo/

# Local DB dump backups must never live in the repo tree (real backups go
# in /opt/collabrains-backups/, outside git) — same risk class as the
# JWT_SECRET-in-public-repo incident (ADR 0052/0053).
backups/
*.dump
*.rdb

# Python test tooling artifacts -- previously only excluded via their own
# self-generated nested .gitignore (services/api/.venv-test/.gitignore,
# .pytest_cache/.gitignore), which is fragile if either tool ever stops
# writing that file (ADR 0066 audit finding).
.venv-test/
.pytest_cache/

# Playwright
apps/e2e/test-results/
apps/e2e/playwright-report/
apps/e2e/.cache/
